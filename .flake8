[flake8]
max-line-length = 88
extend-ignore = E203, W503

per-file-ignores =
    utils/import_logging.py: F401
    tests/data_processing/__init__.py: F401, F811
    tests/utils/__init__.py: E402
    tests/utils/test_data_loader.py: E402
    tests/test_data_validator_security.py: E402
    tests/test_refactoring_agent_workflow.py: E402
    tests/test_sanitize_filename.py: E402
